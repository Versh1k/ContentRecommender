@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ContentRecommender.Data.Repositories
@attribute [Authorize]
@inject IFavoritesRepository FavoritesRepository
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="home-page">
    <div class="home-container">
        <div class="home-header">
            <h1 class="home-title">Советник настроения</h1>
            <div class="user-actions">
                <a href="/favorites" class="favorites-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                    </svg>
                    <span>Избранное</span>
                    @if (favoritesCount > 0)
                    {
                        <span class="badge">@favoritesCount</span>
                    }
                </a>
                <button class="logout-btn" @onclick="Logout">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    <span>Выйти</span>
                </button>
            </div>
        </div>

        <div class="hero-section">
            <div class="hero-content">
                <h2 class="hero-title">Найдите идеальный контент под ваше настроение</h2>
                <p class="hero-subtitle">Фильмы, сериалы, мультфильмы, аниме и книги — всё в одном месте</p>
                <a href="/search" class="btn-primary btn-large">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <path d="M21 21l-4.35-4.35" />
                    </svg>
                    <span>Начать поиск</span>
                </a>
            </div>
            <div class="hero-decoration">
                <div class="decoration-circle circle-1"></div>
                <div class="decoration-circle circle-2"></div>
                <div class="decoration-circle circle-3"></div>
            </div>
        </div>

        <div class="features-section">
            <div class="features-grid">
                <div class="feature-card">
                    <h4>Подбор по настроению</h4>
                    <p>Умный анализ текста и ML-модель для точного определения вашего настроения</p>
                </div>
                <div class="feature-card">
                    <h4>Фильмы и сериалы</h4>
                    <p>База Кинопоиска с рейтингами, описаниями и обложками в высоком качестве</p>
                </div>
                <div class="feature-card">
                    <h4>Книги</h4>
                    <p>Google Books API — тысячи книг с подробной информацией</p>
                </div>
                <div class="feature-card">
                    <h4>Избранное</h4>
                    <p>Сохраняйте понравившийся контент и возвращайтесь к нему в любое время</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int favoritesCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;

            if (user?.Identity?.IsAuthenticated == true && !string.IsNullOrEmpty(user.Identity.Name))
            {
                var favorites = await FavoritesRepository.GetUserFavoritesAsync(user.Identity.Name);
                favoritesCount = favorites.Count;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при загрузке избранного: {ex.Message}");
            favoritesCount = 0;
        }
    }

    private async Task Logout()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState?.User?.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/Account/Logout", true);
        }
    }
}