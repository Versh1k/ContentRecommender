@page "/content/{Source}/{Id}"
@using ContentRecommender.Core.Models
@using ContentRecommender.Core.Services
@using ContentRecommender.Web.Services
@inject IContentDetailService DetailService
@inject IFavoritesService FavoritesService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject Microsoft.Extensions.Options.IOptions<ContentRecommender.Core.Configuration.MovieApiOptions> MovieOptions
@inject Microsoft.Extensions.Options.IOptions<ContentRecommender.Core.Configuration.BookApiOptions> BookOptions

@if (isLoading)
{
    <div class="loading-container">
        <div class="spinner-large"></div>
        <p>Загрузка...</p>
    </div>
}
else if (content == null)
{
    <div class="error-container">
        <h2>Контент не найден</h2>
        <p>Запрашиваемая страница не существует или была удалена</p>
        <a href="/" class="btn-primary">На главную</a>
    </div>
}
else
{
    <div class="content-detail-page">
        <div class="detail-header">
            <a href="javascript:history.back()" class="back-button">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7" />
                </svg>
                <span>Назад</span>
            </a>

            <div class="detail-actions">
                <button class="action-btn @(content.IsFavorite ? "active" : "")"
                        @onclick="ToggleFavorite"
                        title="@(content.IsFavorite ? "Удалить из избранного" : "В избранное")">
                    @(content.IsFavorite ? "❤️" : "🤍")
                </button>
                <button class="action-btn share-btn"
                        @onclick="ShareContent"
                        title="Копировать ссылку">
                    🔗
                </button>
            </div>
        </div>

        <div class="detail-content">
            <div class="detail-poster">
                @if (!string.IsNullOrEmpty(content.CoverUrl))
                {
                    <img src="@content.CoverUrl" alt="@content.Title" />
                }
                else
                {
                    <div class="no-poster">
                        <span>@GetFormatIcon(content.Format)</span>
                    </div>
                }
            </div>

            <div class="detail-info">
                <h1 class="detail-title">@content.Title</h1>

                <div class="detail-meta">
                    @if (content.Rating.HasValue)
                    {
                        <span class="rating">⭐ @content.Rating.Value.ToString("F1")</span>
                    }
                    @if (content.Year.HasValue)
                    {
                        <span>• @content.Year</span>
                    }
                    @if (content.DurationMinutes.HasValue)
                    {
                        <span>• @content.DurationMinutes мин</span>
                    }
                    @if (content.Pages.HasValue)
                    {
                        <span>• @content.Pages стр</span>
                    }
                </div>

                @if (content.Genres?.Any() == true)
                {
                    <div class="detail-genres">
                        @foreach (var genre in content.Genres.Take(5))
                        {
                            <span class="genre-tag">@genre</span>
                        }
                    </div>
                }

                <div class="detail-description">
                    <p>@(content.Description ?? "Описание отсутствует")</p>
                </div>

                @if (!string.IsNullOrEmpty(content.Director))
                {
                    <div class="detail-crew">
                        <strong>Режиссёр:</strong> @content.Director
                    </div>
                }

                @if (!string.IsNullOrEmpty(content.Author))
                {
                    <div class="detail-crew">
                        <strong>Автор:</strong> @content.Author
                    </div>
                }

                <div class="detail-buttons">
                    <a href="@GetExternalUrl(content.Source, content.ExternalId)" target="_blank" class="btn-external">
                        @GetExternalButtonText(content.Source)
                    </a>
                </div>
            </div>
        </div>

        @if (content.SimilarItems?.Any() == true)
        {
            <div class="similar-section">
                <h2>Похожие</h2>
                <div class="similar-grid">
                    @foreach (var similar in content.SimilarItems)
                    {
                        <div class="similar-card" @onclick="() => NavigateToContent(similar.Source, similar.ExternalId)">
                            @if (!string.IsNullOrEmpty(similar.CoverUrl))
                            {
                                <img src="@similar.CoverUrl" alt="@similar.Title" />
                            }
                            else
                            {
                                <div class="no-poster-small">
                                    <span>@GetFormatIcon(similar.Format)</span>
                                </div>
                            }
                            <div class="similar-info">
                                <h4>@similar.Title</h4>
                                @if (similar.Rating.HasValue)
                                {
                                    <span class="similar-rating">⭐ @similar.Rating.Value.ToString("F1")</span>
                                }
                                @if (similar.Year.HasValue)
                                {
                                    <span class="similar-year">@similar.Year</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Source { get; set; } = "";
    [Parameter] public string Id { get; set; } = "";

    private ContentDetailDto? content;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadContent();
    }

    private async Task LoadContent()
    {
        try
        {
            isLoading = true;
            content = await DetailService.GetContentDetailsAsync(Source, Id);
            if (content != null)
            {
                content.SimilarItems = await DetailService.GetSimilarContentAsync(Source, Id, 6);
                content.IsFavorite = await FavoritesService.IsFavoriteAsync(content.ExternalId, content.Source);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
            content = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleFavorite()
    {
        if (content == null) return;

        ContentItem item = content.Format switch
        {
            ContentFormat.Book => new Book
            {
                ExternalId = content.ExternalId,
                Source = content.Source,
                Format = content.Format,
                Title = content.Title,
                CoverUrl = content.CoverUrl,
                Author = content.Author,
                Pages = content.Pages,
                Year = content.Year,
                Rating = content.Rating,
                Genres = content.Genres,
                Description = content.Description
            },
            _ => new Movie
            {
                ExternalId = content.ExternalId,
                Source = content.Source,
                Format = content.Format,
                Title = content.Title,
                CoverUrl = content.CoverUrl,
                Director = content.Director,
                DurationMinutes = content.DurationMinutes,
                Year = content.Year,
                Rating = content.Rating,
                Genres = content.Genres,
                Description = content.Description
            }
        };

        bool newState = await FavoritesService.ToggleFavoriteAsync(item);
        if (content.IsFavorite != newState)
        {
            content.IsFavorite = newState;
            StateHasChanged();
        }
    }

    private async Task ShareContent()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", Navigation.Uri);
    }

    private void NavigateToContent(string source, string externalId)
    {
        Navigation.NavigateTo($"/content/{source.ToLower()}/{externalId}");
    }

    // === АБСТРАКТНЫЕ МЕТОДЫ (без хардкода) ===

    // Получаем текст кнопки из конфига или дефолт
    private string GetExternalButtonText(string source)
    {
        var normalized = source.ToLowerInvariant();

        // Проверяем через конфиг: какой провайдер активен для фильмов/книг
        var movieProvider = MovieOptions.Value.ActiveProvider.ToLowerInvariant();
        var bookProvider = BookOptions.Value.ActiveProvider.ToLowerInvariant();

        if (normalized == movieProvider)
        {
            // Можно добавить в конфиг: "ButtonText": "Открыть на Кинопоиске"
            // Пока дефолтное значение
            return "Открыть в источнике";
        }
        else if (normalized == bookProvider)
        {
            return "Читать в источнике";
        }

        // Универсальный фоллбэк
        return "Открыть";
    }

    // Строим внешний URL полностью из конфига
    private string GetExternalUrl(string source, string externalId)
    {
        var normalized = source.ToLowerInvariant();
        var movieProvider = MovieOptions.Value.ActiveProvider.ToLowerInvariant();
        var bookProvider = BookOptions.Value.ActiveProvider.ToLowerInvariant();

        if (normalized == movieProvider)
        {
            var provider = MovieOptions.Value.Providers[MovieOptions.Value.ActiveProvider];
            // BaseUrl: https://kinopoiskapiunofficial.tech/api/v2.2/films
            // Нужно превратить в: https://kinopoisk.ru/film/123456/
            // Это можно настроить в конфиге через отдельное поле ExternalUrlTemplate
            // Пока делаем простую эвристику:
            if (provider.BaseUrl.Contains("kinopoisk"))
                return $"https://kinopoisk.ru/film/{externalId}/";
        }
        else if (normalized == bookProvider)
        {
            var provider = BookOptions.Value.Providers[BookOptions.Value.ActiveProvider];
            if (provider.BaseUrl.Contains("googleapis.com/books"))
                return $"https://books.google.com/books?id={externalId}";
        }

        // Универсальный фоллбэк: просто открываем BaseUrl + ID
        // Это можно улучшить, добавив в конфиг поле "ExternalUrlTemplate": "https://example.com/item/{id}"
        return $"{GetProviderBaseUrl(source)}/{externalId}";
    }

    // Вспомогательный метод: получаем BaseUrl провайдера по source
    private string GetProviderBaseUrl(string source)
    {
        var normalized = source.ToLowerInvariant();

        if (normalized == MovieOptions.Value.ActiveProvider.ToLowerInvariant())
            return MovieOptions.Value.Providers[MovieOptions.Value.ActiveProvider].BaseUrl;

        if (normalized == BookOptions.Value.ActiveProvider.ToLowerInvariant())
            return BookOptions.Value.Providers[BookOptions.Value.ActiveProvider].BaseUrl;

        return "#";
    }

    private string GetFormatIcon(ContentFormat format) => format switch
    {
        ContentFormat.Movie => "🎬",
        ContentFormat.Series => "📺",
        ContentFormat.Cartoon => "🎨",
        ContentFormat.Book => "📚",
        _ => "🎬"
    };
}