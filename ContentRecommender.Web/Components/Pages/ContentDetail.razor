@page "/content/{Source}/{Id}"
@using ContentRecommender.Core.Models
@using ContentRecommender.Core.Services
@using ContentRecommender.Web.Services
@using ContentRecommender.Core.Configuration
@inject IContentDetailService DetailService
@inject IFavoritesService FavoritesService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject Microsoft.Extensions.Options.IOptions<MovieApiOptions> MovieOptions
@inject Microsoft.Extensions.Options.IOptions<BookApiOptions> BookOptions

@if (isLoading)
{
    <div class="loading-container">
        <div class="spinner-large"></div>
        <p>Загрузка...</p>
    </div>
}
else if (content == null)
{
    <div class="error-container">
        <h2>Контент не найден</h2>
        <p>Запрашиваемая страница не существует или была удалена</p>
        <a href="/" class="btn-primary">На главную</a>
    </div>
}
else
{
    <div class="content-detail-page">
        <div class="detail-header">
            <a href="javascript:history.back()" class="back-button">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7" />
                </svg>
                <span>Назад</span>
            </a>
            <div class="detail-actions">
                <button class="action-btn @(content.IsFavorite ? "active" : "")"
                        @onclick="ToggleFavorite"
                        title="@(content.IsFavorite ? "Удалить из избранного" : "В избранное")">
                    @(content.IsFavorite ? "❤️" : "🤍")
                </button>
                <button class="action-btn share-btn" @onclick="ShareContent" title="Копировать ссылку">🔗</button>
            </div>
        </div>

        <div class="detail-content">
            <div class="detail-poster">
                @if (!string.IsNullOrEmpty(content.CoverUrl))
                {
                    <img src="@content.CoverUrl" alt="@content.Title" />
                }
                else
                {
                    <div class="no-poster">📷</div>
                }
            </div>
            <div class="detail-info">
                <h1 class="detail-title">@content.Title</h1>
                <div class="detail-meta">
                    @if (content.Rating.HasValue)
                    {
                        <span class="rating">⭐ @content.Rating.Value.ToString("F1")</span>
                    }
                    @if (content.Year.HasValue)
                    {
                        <span>• @content.Year</span>
                    }
                    @if (content.DurationMinutes.HasValue)
                    {
                        <span>• @content.DurationMinutes мин</span>
                    }
                    @if (content.Pages.HasValue)
                    {
                        <span>• @content.Pages стр</span>
                    }
                </div>
                @if (content.Genres?.Any() == true)
                {
                    <div class="detail-genres">
                        @foreach (var genre in content.Genres.Take(5))
                        {
                            <span class="genre-tag">@genre</span>
                        }
                    </div>
                }
                <div class="detail-description">
                    <p>@(content.Description ?? "Описание отсутствует")</p>
                </div>
                @if (!string.IsNullOrEmpty(content.Director))
                {
                    <div class="detail-crew"><strong>Режиссёр:</strong> @content.Director</div>
                }
                @if (!string.IsNullOrEmpty(content.Author))
                {
                    <div class="detail-crew"><strong>Автор:</strong> @content.Author</div>
                }
                <div class="detail-buttons">
                    <a href="@GetExternalUrl(content.Source, content.ExternalId)" target="_blank" class="btn-external">
                        @GetExternalButtonText(content.Source)
                    </a>
                </div>
            </div>
        </div>

        @if (content.SimilarItems != null && content.SimilarItems.Any())
        {
            <div class="similar-section">
                <h2>Похожие рекомендации</h2>
                <div class="carousel-wrapper">
                    @if (content.SimilarItems.Count > 4)
                    {
                        <button class="carousel-btn prev" @onclick="Prev" disabled="@(_startIndex == 0)">‹</button>
                    }
                    <div class="carousel-track">
                        @foreach (var similar in visibleItems)
                        {
                            <div class="carousel-card" @onclick="() => NavigateToContent(similar.Source, similar.ExternalId)">
                                @if (!string.IsNullOrEmpty(similar.CoverUrl))
                                {
                                    <img src="@similar.CoverUrl" alt="@similar.Title" />
                                }
                                else
                                {
                                    <div class="no-poster-small">🎬</div>
                                }
                                <div class="carousel-info">
                                    <h4>@similar.Title</h4>
                                    <div class="carousel-meta">
                                        @if (similar.Rating.HasValue)
                                        {
                                            <span class="carousel-rating">⭐ @similar.Rating.Value.ToString("F1")</span>
                                        }
                                        @if (similar.Year.HasValue)
                                        {
                                            <span class="carousel-year">@similar.Year</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    @if (content.SimilarItems.Count > 4)
                    {
                        <button class="carousel-btn next" @onclick="Next" disabled="@(_startIndex + 4 >= content.SimilarItems.Count)">›</button>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Source { get; set; } = "";
    [Parameter] public string Id { get; set; } = "";

    private ContentDetailDto? content;
    private bool isLoading = true;
    private const int VisibleCount = 4;
    private int _startIndex = 0;

    private List<ContentDetailDto> visibleItems
    {
        get
        {
            if (content?.SimilarItems == null || !content.SimilarItems.Any())
                return new List<ContentDetailDto>();
            return content.SimilarItems.Skip(_startIndex).Take(VisibleCount).ToList();
        }
    }

    protected override async Task OnInitializedAsync() => await LoadContent();
    protected override async Task OnParametersSetAsync() => await LoadContent();

    private async Task LoadContent()
    {
        try
        {
            isLoading = true;
            _startIndex = 0;
            content = await DetailService.GetContentDetailsAsync(Source, Id);
            if (content != null)
            {
                content.SimilarItems = await DetailService.GetSimilarContentAsync(Source, Id, 50);
                content.IsFavorite = await FavoritesService.IsFavoriteAsync(content.ExternalId, content.Source);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
            content = null;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void Prev()
    {
        if (_startIndex > 0)
        {
            _startIndex--;
            StateHasChanged();
        }
    }

    private void Next()
    {
        if (content?.SimilarItems != null && _startIndex + VisibleCount < content.SimilarItems.Count)
        {
            _startIndex++;
            StateHasChanged();
        }
    }

    private async Task ToggleFavorite()
    {
        if (content == null) return;
        ContentItem item = content.Format switch
        {
            ContentFormat.Book => new Book
            {
                ExternalId = content.ExternalId,
                Source = content.Source,
                Format = content.Format,
                Title = content.Title,
                CoverUrl = content.CoverUrl,
                Author = content.Author,
                Pages = content.Pages,
                Year = content.Year,
                Rating = content.Rating,
                Genres = content.Genres,
                Description = content.Description
            },
            _ => new Movie
            {
                ExternalId = content.ExternalId,
                Source = content.Source,
                Format = content.Format,
                Title = content.Title,
                CoverUrl = content.CoverUrl,
                Director = content.Director,
                DurationMinutes = content.DurationMinutes,
                Year = content.Year,
                Rating = content.Rating,
                Genres = content.Genres,
                Description = content.Description
            }
        };
        bool newState = await FavoritesService.ToggleFavoriteAsync(item);
        if (content.IsFavorite != newState)
        {
            content.IsFavorite = newState;
            StateHasChanged();
        }
    }

    private async Task ShareContent() => await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", Navigation.Uri);

    private void NavigateToContent(string source, string externalId)
    {
        Navigation.NavigateTo($"/content/{source.ToLower()}/{externalId}", forceLoad: true);
    }

    private string GetExternalButtonText(string source)
    {
        var normalized = source.ToLowerInvariant();
        var movieProvider = MovieOptions.Value.ActiveProvider.ToLowerInvariant();
        var bookProvider = BookOptions.Value.ActiveProvider.ToLowerInvariant();
        if (normalized == movieProvider) return "Открыть в источнике";
        if (normalized == bookProvider) return "Читать в источнике";
        return "Открыть";
    }

    private string GetExternalUrl(string source, string externalId)
    {
        var normalized = source.ToLowerInvariant();
        var movieProvider = MovieOptions.Value.ActiveProvider.ToLowerInvariant();
        var bookProvider = BookOptions.Value.ActiveProvider.ToLowerInvariant();
        ProviderConfig? provider = null;
        if (normalized == movieProvider)
            provider = MovieOptions.Value.Providers[MovieOptions.Value.ActiveProvider];
        else if (normalized == bookProvider)
            provider = BookOptions.Value.Providers[BookOptions.Value.ActiveProvider];
        if (provider != null && !string.IsNullOrEmpty(provider.PublicLinkTemplate))
            return provider.PublicLinkTemplate.Replace("{id}", externalId);
        return "#";
    }
}