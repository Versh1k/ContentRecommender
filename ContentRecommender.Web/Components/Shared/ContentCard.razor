@using ContentRecommender.Core.Models
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@if (Item != null)
{
    <div class="content-card @GetMoodClass(Item.MoodTags?.FirstOrDefault())" @onclick="NavigateToDetail">
        <div class="card-cover-container">
            @if (!string.IsNullOrEmpty(Item.CoverUrl))
            {
                <img src="@Item.CoverUrl" alt="@Item.Title" class="cover-image" />
            }
            else
            {
                <div class="image-fallback">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        @if (Item.Format == ContentFormat.Book)
                        {
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        }
                        else
                        {
                            <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect>
                            <line x1="7" y1="2" x2="7" y2="22"></line>
                            <line x1="17" y1="2" x2="17" y2="22"></line>
                            <line x1="2" y1="12" x2="22" y2="12"></line>
                        }
                    </svg>
                    <span>@(Item.Format == ContentFormat.Book ? "Обложка" : "Постер")</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(Item.Description))
            {
                <div class="cover-overlay">
                    <p>@TruncateDescription(Item.Description, 150)</p>
                </div>
            }

            <button class="favorite-btn @(IsFavorite ? "active" : "")"
                    @onclick="HandleToggleFavorite"
                    @onclick:stopPropagation="true"
                    title="@(IsFavorite ? "Удалить из избранного" : "В избранное")">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                </svg>
            </button>

            <div class="detail-hint">
                <span>📄 Подробнее</span>
            </div>
        </div>

        <div class="card-content">
            <h3 class="card-title">@Item.Title</h3>

            <div class="card-meta">
            @if (Item.Year.HasValue)
            {
                <span>@Item.Year</span>
            }
            @if (Item.Rating.HasValue)
            {
                <span>• ⭐ @Item.Rating.Value.ToString("F1")</span>
            }
            @if (Item is Book book && book.Pages.HasValue)
            {
                <span>• @book.Pages стр</span>
            }
            else if (Item is Movie movie && movie.DurationMinutes.HasValue)
            {
                <span>• @movie.DurationMinutes мин</span>
            }
            </div>

            @if (!string.IsNullOrEmpty(GetSecondaryInfo()))
            {
                <div class="card-secondary">
                    <span>@GetSecondaryInfo()</span>
                </div>
            }

            @if (Item.Genres?.Any() == true)
            {
                <div class="card-genres">
                    @foreach (var genre in Item.Genres.Take(3))
                    {
                        <span class="genre-tag">@genre</span>
                    }
                </div>
            }
        </div>

        <button class="source-icon"
                @onclick="OpenInNewTab"
                @onclick:stopPropagation="true"
                title="@(Item.Format == ContentFormat.Book ? "Открыть на Google Books" : "Открыть на Кинопоиске")">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
        </button>
    </div>
}
else
{
    Console.WriteLine("⚠️ ContentCard: Item is null!");
}

@code {
    [Parameter] public ContentItem? Item { get; set; }
    [Parameter] public EventCallback<ContentItem> OnFavoriteChanged { get; set; }
    [Parameter] public bool IsFavorite { get; set; }

    private void NavigateToDetail()
    {
        if (Item != null && !string.IsNullOrEmpty(Item.Source) && !string.IsNullOrEmpty(Item.ExternalId))
        {
            Navigation.NavigateTo($"/content/{Item.Source.ToLower()}/{Item.ExternalId}");
        }
    }

    private async Task HandleToggleFavorite()
    {
        if (Item != null && OnFavoriteChanged.HasDelegate)
        {
            Console.WriteLine($"❤️ ToggleFavorite вызван для: {Item.Title}");
            await OnFavoriteChanged.InvokeAsync(Item);
        }
        else
        {
            Console.WriteLine($"⚠️ OnFavoriteChanged.HasDelegate = {OnFavoriteChanged.HasDelegate}");
        }
    }

    private async Task OpenInNewTab()
    {
        if (Item == null) return;

        string url = Item.Source?.ToLower() switch
        {
            "kinopoisk" => $"https://www.kinopoisk.ru/film/{Item.ExternalId}/",
            "googlebooks" => $"https://www.google.com/books/edition/-/{Item.ExternalId}",
            _ => Item.Source?.ToLower() == "googlebooks"
                ? $"https://books.google.com/books?id={Item.ExternalId}"
                : "https://www.kinopoisk.ru/"
        };
        await JSRuntime.InvokeVoidAsync("open", url, "_blank");
    }

    private string TruncateDescription(string description, int maxLength)
    {
        if (string.IsNullOrEmpty(description)) return "Описание отсутствует";
        if (description.Length <= maxLength) return description;
        return description.Substring(0, maxLength) + "...";
    }

    private string GetMoodClass(MoodType? mood)
    {
        if (mood == null) return "mood-calm";
        return mood switch
        {
            MoodType.Epic => "mood-epic",
            MoodType.Romantic => "mood-romantic",
            MoodType.Mysterious => "mood-mysterious",
            MoodType.Funny => "mood-funny",
            MoodType.Sad => "mood-sad",
            MoodType.Inspiring => "mood-inspiring",
            MoodType.Tense => "mood-tense",
            MoodType.Everyday => "mood-everyday",
            _ => "mood-calm"
        };
    }

    private string? GetSecondaryInfo()
    {
        if (Item is Movie movie && !string.IsNullOrWhiteSpace(movie.Director))
            return $"Реж. {movie.Director}";

        if (Item is Book book && !string.IsNullOrWhiteSpace(book.Author))
            return book.Author;

        return null;  // ✅ Не показываем "Неизвестен"
    }
}