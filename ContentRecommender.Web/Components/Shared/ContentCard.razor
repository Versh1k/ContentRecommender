@using ContentRecommender.Core.Models
@using ContentRecommender.Core.Configuration
@using Microsoft.Extensions.Options

@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IOptions<MovieApiOptions> MovieOptions
@inject IOptions<BookApiOptions> BookOptions
@inject IOptions<MoodModelOptions> MoodOptions

@if (Item != null)
{
    <div class="content-card @GetMoodClass(Item.MoodTags?.FirstOrDefault()) @GetFormatClass()" @onclick="NavigateToDetail">
        <div class="card-cover-container">
            @if (!string.IsNullOrEmpty(Item.CoverUrl))
            {
                <img src="@Item.CoverUrl" alt="@Item.Title" class="cover-image" />
            }
            else
            {
                <div class="image-fallback">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        @if (Item.Format == ContentFormat.Book)
                        {
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        }
                        else
                        {
                            <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect>
                            <line x1="7" y1="2" x2="7" y2="22"></line>
                            <line x1="17" y1="2" x2="17" y2="22"></line>
                            <line x1="2" y1="12" x2="22" y2="12"></line>
                        }
                    </svg>
                    <span>@(Item.Format == ContentFormat.Book ? "Обложка" : "Постер")</span>
                </div>
            }

            <button class="favorite-btn @(IsFavorite ? "active" : "")"
                    @onclick="HandleToggleFavorite"
                    @onclick:stopPropagation="true"
                    title="@(IsFavorite ? "Удалить из избранного" : "В избранное")">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                </svg>
            </button>

            <div class="detail-hint">
                <span>📄 Подробнее</span>
            </div>
        </div>

        <div class="card-content" style="position: relative;">
            <h3 class="card-title">@Item.Title</h3>

            <div class="card-meta">
                @if (Item.Year.HasValue)
                {
                    <span>@Item.Year</span>
                }
                @if (Item.Rating.HasValue)
                {
                    <span>• ⭐ @Item.Rating.Value.ToString("F1")</span>
                }
                @if (Item is Book book && book.Pages.HasValue)
                {
                    <span>• @book.Pages стр</span>
                }
                else if (Item is Movie movie && movie.DurationMinutes.HasValue)
                {
                    <span>• @movie.DurationMinutes мин</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(GetSecondaryInfo()))
            {
                <div class="card-secondary">
                    <span>@GetSecondaryInfo()</span>
                </div>
            }

            <div class="card-genres">
                @if (Status.HasValue)
                {
                    <div class="card-status-wrapper">
                        <div class="status-dropdown-container dropup" @onclick:stopPropagation="true">
                            <span class="genre-tag status-tag @GetStatusClass(Status.Value)"
                                  @onclick="ToggleStatusDropdown">
                                @GetStatusLabel(Status.Value)
                            </span>
                            @if (isStatusDropdownOpen)
                            {
                                <div class="status-dropdown-menu dropup-menu">
                                    @foreach (var status in Enum.GetValues<FavoriteStatus>())
                                    {
                                        <div class="status-dropdown-item @(status == Status.Value ? "active" : "")"
                                             @onclick="() => SelectStatus(status)">
                                            @GetStatusLabel(status)
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                @if (Item.Genres?.Any() == true)
                {
                    @foreach (var genre in Item.Genres.Take(3))
                    {
                        <span class="genre-tag">@genre</span>
                    }
                }
            </div>
        </div>

        <button class="source-icon"
                @onclick="OpenInNewTab"
                @onclick:stopPropagation="true"
                title="@GetExternalButtonText()">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
        </button>
    </div>
}

@code {
    [Parameter] public ContentItem? Item { get; set; }
    [Parameter] public EventCallback<ContentItem> OnFavoriteChanged { get; set; }
    [Parameter] public bool IsFavorite { get; set; }
    [Parameter] public FavoriteStatus? Status { get; set; }

    private bool isStatusDropdownOpen = false;

    private void ToggleStatusDropdown()
    {
        isStatusDropdownOpen = !isStatusDropdownOpen;
    }

    private async Task SelectStatus(FavoriteStatus status)
    {
        isStatusDropdownOpen = false;
        Status = status;
        if (OnStatusChanged.HasDelegate)
            await OnStatusChanged.InvokeAsync(status);
    }

    [Parameter] public EventCallback<FavoriteStatus> OnStatusChanged { get; set; }

    private string GetStatusClass(FavoriteStatus status) => status switch
    {
        FavoriteStatus.Planned => "status-planned",
        FavoriteStatus.InProgress => "status-inprogress",
        FavoriteStatus.Completed => "status-completed",
        FavoriteStatus.Postponed => "status-postponed",
        FavoriteStatus.Dropped => "status-dropped",
        _ => ""
    };

    private string GetStatusLabel(FavoriteStatus status) => status switch
    {
        FavoriteStatus.Planned => "В планах",
        FavoriteStatus.InProgress => "В процессе",
        FavoriteStatus.Completed => "Просмотрено",
        FavoriteStatus.Postponed => "Отложено",
        FavoriteStatus.Dropped => "Брошено",
        _ => ""
    };

    private void NavigateToDetail()
    {
        if (Item != null && !string.IsNullOrEmpty(Item.Source) && !string.IsNullOrEmpty(Item.ExternalId))
        {
            Navigation.NavigateTo($"/content/{Item.Source.ToLower()}/{Item.ExternalId}");
        }
    }

    private async Task HandleToggleFavorite()
    {
        if (Item != null && OnFavoriteChanged.HasDelegate)
        {
            await OnFavoriteChanged.InvokeAsync(Item);
        }
    }

    private async Task OpenInNewTab()
    {
        if (Item == null || string.IsNullOrEmpty(Item.ExternalId) || string.IsNullOrEmpty(Item.Source))
            return;

        var url = GetExternalUrl();
        if (!string.IsNullOrEmpty(url) && url != "#")
            await JSRuntime.InvokeVoidAsync("open", url, "_blank", "noopener,noreferrer");
    }
    private string GetFormatClass()
    {
        if (Status.HasValue)
        {
            return Item?.Format switch
            {
                ContentFormat.Movie => "format-movie",
                ContentFormat.Series => "format-series",
                ContentFormat.Cartoon => "format-cartoon",
                ContentFormat.Book => "format-book",
                _ => ""
            };
        }
        return "";
    }
    private string GetExternalUrl()
    {
        if (string.IsNullOrEmpty(Item?.ExternalId) || string.IsNullOrEmpty(Item?.Source))
            return "#";

        if (Item.Format == ContentFormat.Book)
        {
            var cfg = BookOptions.Value.Providers.TryGetValue(Item.Source, out var bc) ? bc : null;
            if (cfg == null) return "#";
            var template = cfg.ExternalUrlTemplate;
            return string.IsNullOrEmpty(template)
                ? $"https://books.google.com/books?id={Item.ExternalId}"
                : template.Replace("{id}", Item.ExternalId).Replace("{BaseUrl}", cfg.BaseUrl);
        }
        else
        {
            var cfg = MovieOptions.Value.Providers.TryGetValue(Item.Source, out var mc) ? mc : null;
            if (cfg == null) return "#";
            var template = mc.ExternalUrlTemplate;
            return string.IsNullOrEmpty(template)
                ? $"https://www.kinopoisk.ru/film/{Item.ExternalId}/"
                : template.Replace("{id}", Item.ExternalId).Replace("{BaseUrl}", mc.BaseUrl);
        }
    }

    private string GetExternalButtonText()
    {
        if (string.IsNullOrEmpty(Item?.Source)) return "Открыть";
        if (Item.Format == ContentFormat.Book)
        {
            var cfg = BookOptions.Value.Providers.TryGetValue(Item.Source, out var bc) ? bc : null;
            return string.IsNullOrEmpty(cfg?.ExternalButtonText) ? "Читать" : cfg.ExternalButtonText;
        }
        var mCfg = MovieOptions.Value.Providers.TryGetValue(Item.Source, out var mc) ? mc : null;
        return string.IsNullOrEmpty(mCfg?.ExternalButtonText) ? "Открыть" : mCfg.ExternalButtonText;
    }

    private string GetMoodClass(string? mood)
    {
        if (string.IsNullOrEmpty(mood))
            return MoodOptions.Value.DefaultCssClass;
        var moodItem = MoodOptions.Value.Classes.FirstOrDefault(c => c.Name == mood);
        return moodItem?.CssClass ?? MoodOptions.Value.DefaultCssClass;
    }

    private string? GetSecondaryInfo()
    {
        if (Item is Movie movie && !string.IsNullOrWhiteSpace(movie.Director))
            return $"Реж. {movie.Director}";
        if (Item is Book book && !string.IsNullOrWhiteSpace(book.Author))
            return book.Author;
        return null;
    }
}