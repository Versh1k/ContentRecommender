@page
@model ContentRecommender.Web.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">Регистрация</h2>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.FirstName">Имя</label>
                <input asp-for="Input.FirstName" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Input.LastName">Фамилия</label>
                <input asp-for="Input.LastName" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Пароль</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
                <small class="text-muted">Минимум 6 символов</small>
            </div>

            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Подтвердите пароль</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-primary btn-block">Зарегистрироваться</button>
        </form>

        <div class="auth-links">
            <a href="/account/login">Уже есть аккаунт? Войти</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}